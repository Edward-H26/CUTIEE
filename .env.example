# =============================================================================
# CUTIEE — single source of truth for environment configuration
# Copy this file to `.env` and fill in the secrets. NEVER commit `.env`.
#
# This file replaces both the old `.env.example` and `.env.cutiee.template`.
# Sections are ordered by required-ness: top section is required for every
# deployment; later sections only matter if you opt into the relevant feature.
# =============================================================================

# ─── 1. Deployment environment (REQUIRED) ────────────────────────────────────
# Must be exactly "local" or "production". Unset raises at startup; there is
# no silent fallback. Local mode uses Qwen + dockerised Neo4j; production mode
# uses Gemini + Neo4j AuraDB.
CUTIEE_ENV=local

# ─── 2. Django (REQUIRED) ────────────────────────────────────────────────────
# Generate a 50+-char SECRET_KEY for production. Production also requires
# DJANGO_DEBUG=False and a real DJANGO_ALLOWED_HOSTS.
DJANGO_SECRET_KEY="cutiee-insecure-dev-only-change-me-50-chars-minimum-xxxxxx"
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS="localhost,127.0.0.1"
DJANGO_CSRF_TRUSTED_ORIGINS="http://localhost:8000,http://127.0.0.1:8000"

# Internal SQLite for Django's auth / session / migration tables only. Domain
# data (tasks, executions, bullets, audit) lives in Neo4j. Use a real path
# (NOT `:memory:`) so the django_site row survives a restart.
DJANGO_INTERNAL_DB_URL="sqlite:///data/django_internals.sqlite3"

# Email backend for allauth (signup confirmations, password resets). Console
# is fine for local; production should use sendgrid / mailgun / postmark.
EMAIL_BACKEND="django.core.mail.backends.console.EmailBackend"

# ─── 3. Neo4j (REQUIRED — primary domain database) ───────────────────────────
# Local : `./scripts/neo4j_up.sh` brings up neo4j:5 in docker on localhost:7687
# Prod  : AuraDB Free — sign up at https://console.neo4j.io/ and copy the
#         neo4j+s://... bolt URL plus credentials into a private secret store.
# NEO4J_URI is accepted as an alias for NEO4J_BOLT_URL (miramemoria-style).
NEO4J_BOLT_URL="bolt://localhost:7687"
NEO4J_USERNAME="neo4j"
NEO4J_PASSWORD="cutiee-dev-password"
NEO4J_DATABASE="neo4j"

# ─── 4. Google OAuth (REQUIRED — primary auth flow) ──────────────────────────
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URIs (add BOTH; allauth path is /accounts/...):
#   Local : http://localhost:8000/accounts/google/login/callback/
#   Prod  : https://<your-render-host>/accounts/google/login/callback/
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── 5. Credential encryption (REQUIRED) ─────────────────────────────────────
# Fernet key used to encrypt SemanticCredentialStore entries at rest.
# Generate with:
#   uv run python -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'
CUTIEE_CREDENTIAL_KEY=""

# ─── 6. Local mode notes ─────────────────────────────────────────────────────
# CUTIEE_ENV=local now means "use the MockComputerUseClient + StubBrowserController"
# for offline development. There is no local LLM that supports the ComputerUse
# tool, so true local mode runs scripted actions only. Tasks executed in local
# mode produce predictable demo output but do NOT drive a real browser.
#
# To run real Computer Use locally, set CUTIEE_ENV=production and supply a
# GEMINI_API_KEY; everything else (Neo4j, Playwright) works the same.

# ─── 7. Computer Use model (Gemini) ──────────────────────────────────────────
# Required when CUTIEE_ENV=production. Get a key at https://aistudio.google.com.
#
# CUTIEE only ships the Computer Use runner (screenshot + pixel coordinates).
# The DOM-router stack was removed once Gemini Flash gained the ComputerUse
# tool at flash pricing.
#
# Default model: gemini-flash-latest (auto-tracks Google's current Flash).
# Pin to gemini-3-flash-preview for deterministic replay.
# The dedicated specialty preview is gemini-2.5-computer-use-preview-10-2025
# (~8x more expensive — only use if Flash CU isn't enough for your workflow).
GEMINI_API_KEY=""
CUTIEE_CU_MODEL="gemini-flash-latest"

# ─── 8. Browser controller (Playwright) ──────────────────────────────────────
# Default: visible window so the user can watch the agent. Flip to true for CI.
CUTIEE_BROWSER_HEADLESS=false
# Optional: a Chrome --remote-debugging-port=9222 URL to attach to your real
# already-open Chrome instead of launching a fresh chromium. With CDP attach
# you inherit all real cookies, extensions, and open tabs.
CUTIEE_BROWSER_CDP_URL=""
# Optional: extra delay between actions for visibility during demos (ms).
CUTIEE_BROWSER_SLOW_MO_MS=0
# Optional: path to a Playwright storage_state.json. Generate via
#   uv run python scripts/capture_storage_state.py
# Sign in once, save cookies; every subsequent CU run is pre-authenticated.
# Per-domain files at data/storage_state/<domain>.json take precedence.
CUTIEE_STORAGE_STATE_PATH=""

# Render's web tier ships without `playwright install chromium`, so the demo
# deploy stubs the browser. Local + worker dynos with Playwright installed
# should set this to false.
CUTIEE_USE_STUB_BROWSER=false

# ─── 9. Live-progress backend (HTMX poll cache) ──────────────────────────────
# memory : in-process dict (default; single-worker dev / tests)
# redis  : shared Redis hash; requires REDIS_URL
# neo4j  : :ProgressSnapshot nodes in Aura with lazy TTL sweep (no Redis dyno)
CUTIEE_PROGRESS_BACKEND=memory
REDIS_URL=""

# ─── 10. Memory + retrieval tuning ───────────────────────────────────────────
CUTIEE_TEMPLATE_MATCH_THRESHOLD=0.85

# ─── 11. Safety + lifecycle ──────────────────────────────────────────────────
CUTIEE_REQUIRE_APPROVAL_HIGH_RISK=true
CUTIEE_MAX_STEPS_PER_TASK=30
# How long to keep per-step CU screenshots in Neo4j before lazy sweep deletes them.
CUTIEE_SCREENSHOT_TTL_DAYS=3

# ─── 12. Runtime paths ───────────────────────────────────────────────────────
CUTIEE_DATA_DIR="./data"
CUTIEE_MODEL_DIR="./data/models"
