# -----------------------------------------------------------------------------
# CUTIEE .env template — Neo4j-default configuration
# Copy the values below into your .env file. Do NOT commit real secrets.
# -----------------------------------------------------------------------------

# Deployment environment — must be "local" or "production". Unset raises.
CUTIEE_ENV=local

# Django
DJANGO_SECRET_KEY="cutiee-insecure-dev-only-change-me"
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS="localhost,127.0.0.1"
DJANGO_INTERNAL_DB_URL="sqlite:///:memory:"

# Neo4j default database
# Local  : `brew install neo4j && brew services start neo4j` OR `./scripts/neo4j_up.sh` (docker)
# Prod   : AuraDB Free — create at https://console.neo4j.io/
NEO4J_BOLT_URL="bolt://localhost:7687"
NEO4J_USERNAME="neo4j"
NEO4J_PASSWORD="cutiee-dev-password"
NEO4J_DATABASE="neo4j"

# Qwen3.5 0.8B local VLM (local mode)
QWEN_SERVER_URL="http://localhost:8001"
QWEN_MODEL_ID="Qwen/Qwen3.5-0.8B-Instruct-GGUF"
QWEN_GGUF_FILENAME="qwen3.5-0.8b-instruct-q4_k_m.gguf"

# Gemini 3.1 variants (production mode)
GEMINI_API_KEY=""
GEMINI_MODEL_TIER1="gemini-3.1-flash-lite"
GEMINI_MODEL_TIER2="gemini-3.1-flash"
GEMINI_MODEL_TIER3="gemini-3.1-pro"

# Runtime paths
CUTIEE_DATA_DIR="./data"
CUTIEE_MODEL_DIR="./data/models"

# Router thresholds
CUTIEE_RECENCY_WINDOW=3
CUTIEE_TEMPLATE_MATCH_THRESHOLD=0.85
CUTIEE_CONFIDENCE_THRESHOLD_TIER1=0.75
CUTIEE_CONFIDENCE_THRESHOLD_TIER2=0.65
CUTIEE_CONFIDENCE_THRESHOLD_TIER3=0.50

# Google OAuth — primary auth flow
# Register at https://console.cloud.google.com/apis/credentials
# Local redirect URI     : http://localhost:8000/accounts/google/login/callback/
# Production redirect URI: https://cutiee.onrender.com/accounts/google/login/callback/
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
