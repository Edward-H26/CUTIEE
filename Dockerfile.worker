# CUTIEE agent worker: Xvfb + Chromium + noVNC.
#
# The worker hosts a single headed Chromium inside a virtual X
# display. The web dyno drives that Chromium over the Chrome DevTools
# Protocol (via Playwright's `connect_over_cdp`), and classmates watch
# the same browser through a noVNC iframe embedded in the dashboard.
#
# Ports:
#   6080  noVNC HTTP (served by websockify; exposed publicly)
#   9222  Chrome DevTools (exposed on the private Render network only,
#         reachable from the web service as http://cutiee-worker:9222)
#   5901  VNC (internal; not exposed)
#
# Build: docker build -f Dockerfile.worker -t cutiee-worker .
# Run:   docker run -p 6080:6080 -p 9222:9222 --env-file .env cutiee-worker

# Stage 1: dependency resolution.
# Splits `uv pip compile` into a dedicated stage so a pyproject.toml
# change only invalidates this small layer. The runtime stage below
# never carries the uv binary, which keeps the deployed image leaner
# and the install path aligned with stock pip.
FROM mcr.microsoft.com/playwright/python:v1.45.0-jammy AS deps-builder

WORKDIR /tmp/build
COPY pyproject.toml ./
# Resolve against the declared `requires-python = ">=3.11"` constraint.
# Both stages use the same Playwright base image so the resolved wheels
# match the runtime Python ABI even though Ubuntu jammy ships Python 3.10.
RUN pip install --no-cache-dir uv \
 && uv pip compile pyproject.toml -o /tmp/build/requirements.txt

# Stage 2: runtime image.
FROM mcr.microsoft.com/playwright/python:v1.45.0-jammy

ENV DEBIAN_FRONTEND=noninteractive \
    DISPLAY=:99 \
    VNC_PORT=5901 \
    NOVNC_PORT=6080 \
    CDP_PORT=9222 \
    PYTHONUNBUFFERED=1

RUN apt-get update && apt-get install -y --no-install-recommends \
        xvfb \
        x11vnc \
        fluxbox \
        novnc \
        websockify \
        tini \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Pull the pinned requirements file from the deps-builder stage and
# install with stock pip so the runtime image carries no uv binary.
# Docker's RUN defaults to `/bin/sh -c`, which is `dash` on Ubuntu;
# referencing /tmp/requirements.txt as a real file (not via `<(...)`
# process substitution) keeps this command POSIX-compliant.
COPY --from=deps-builder /tmp/build/requirements.txt /tmp/requirements.txt
RUN pip install --no-cache-dir -r /tmp/requirements.txt \
 && rm -f /tmp/requirements.txt
# browser-use is intentionally NOT installed here. This image's runtime
# (start-worker.sh) only launches Xvfb, fluxbox, x11vnc, websockify, and
# Chromium; no Python process starts, so browser-use would be dead weight.
# Additionally browser-use requires Python >=3.11 and this Playwright
# base image ships Python 3.10 from Ubuntu jammy, so the install cannot
# succeed on jammy anyway. If a future sidecar lands that runs Python in
# this container AND selects CUTIEE_CU_BACKEND=browser_use, bump the base
# image to a noble variant (Python 3.12) and install browser-use then.
#
# The `local_llm` group (torch, transformers, huggingface-hub) is also
# intentionally NOT installed. The worker runs no Python at runtime, and
# `uv pip compile pyproject.toml` resolves only the base [project]
# dependencies (optional groups are skipped). .dockerignore additionally
# excludes agent/memory/local_llm*.py, scripts/cache_local_qwen.py, and
# tests/agent/test_local_llm.py from the build context so the deployed
# image is free of any Qwen-related Python.

COPY agent/ ./agent/
COPY apps/ ./apps/
COPY cutiee_site/ ./cutiee_site/
COPY scripts/ ./scripts/

RUN mkdir -p /var/log/cutiee /opt/cutiee

# Playwright's base image ships Chromium at
# /ms-playwright/chromium-<rev>/chrome-linux/chrome (binary is named
# `chrome`, not `chromium`) and does NOT put it on PATH. start-worker.sh
# invokes `chromium --no-sandbox ...`, so symlink the Playwright binary
# into /usr/local/bin/chromium. The `--version` probe fails the build if
# the find does not return a runnable binary, so a silent
# command-not-found at runtime becomes a loud build failure here.
RUN if ! command -v chromium >/dev/null 2>&1; then \
        CHROMIUM_BIN="$(find /ms-playwright -type f -name chrome -path '*chromium*' 2>/dev/null | head -1)"; \
        if [ -n "$CHROMIUM_BIN" ]; then \
            ln -s "$CHROMIUM_BIN" /usr/local/bin/chromium; \
        fi; \
    fi \
 && chromium --version

# start-worker.sh runs five long-lived processes:
#   1. Xvfb          virtual X display on :99
#   2. fluxbox       window manager so Chromium has focus + close-buttons
#   3. x11vnc        serve :99 over raw VNC on ${VNC_PORT}
#   4. websockify    wrap VNC in WebSocket + serve /usr/share/novnc at ${NOVNC_PORT}
#   5. chromium      headed on :99, CDP on 0.0.0.0:${CDP_PORT}
#
# The web dyno connects via CDP over Render's private network and drives
# this Chromium through Playwright. The foreground process (`wait`) keeps
# tini alive; if any child dies, the shell exits and Render restarts us.
COPY <<'EOF' /opt/cutiee/start-worker.sh
#!/usr/bin/env bash
set -euo pipefail

Xvfb :99 -screen 0 1280x800x24 +extension RANDR >/var/log/cutiee/xvfb.log 2>&1 &
XVFB_PID=$!
sleep 1

fluxbox >/var/log/cutiee/fluxbox.log 2>&1 &
FLUXBOX_PID=$!

x11vnc -display :99 -forever -nopw -quiet -rfbport ${VNC_PORT} -shared \
    >/var/log/cutiee/x11vnc.log 2>&1 &
X11VNC_PID=$!

websockify --web=/usr/share/novnc --heartbeat=30 ${NOVNC_PORT} localhost:${VNC_PORT} \
    >/var/log/cutiee/websockify.log 2>&1 &
WEBSOCKIFY_PID=$!

# Chromium binds CDP to 0.0.0.0 so Render's private network routes
# http://cutiee-worker:${CDP_PORT} to this process. --no-sandbox is
# safe here because Render containers already run in a sandboxed env.
# --disable-dev-shm-usage prevents OOM-like failures when /dev/shm is
# the default tiny 64 MB mount (Render default).
chromium \
    --no-sandbox \
    --disable-dev-shm-usage \
    --disable-gpu \
    --remote-debugging-port=${CDP_PORT} \
    --remote-debugging-address=0.0.0.0 \
    --user-data-dir=/tmp/chromium-profile \
    --window-size=1280,800 \
    about:blank \
    >/var/log/cutiee/chromium.log 2>&1 &
CHROMIUM_PID=$!

cleanup() {
    kill ${CHROMIUM_PID} ${WEBSOCKIFY_PID} ${X11VNC_PID} ${FLUXBOX_PID} ${XVFB_PID} 2>/dev/null || true
}
trap cleanup EXIT

# Block on Chromium so Render's health check sees a live process.
# If Chromium crashes, the container exits and Render restarts it.
wait ${CHROMIUM_PID}
EOF
RUN chmod +x /opt/cutiee/start-worker.sh

EXPOSE 6080
EXPOSE 9222

ENTRYPOINT ["/usr/bin/tini", "--"]
CMD ["/opt/cutiee/start-worker.sh"]
